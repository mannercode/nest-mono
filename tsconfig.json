{
    "compilerOptions": {
        "module": "commonjs",
        "moduleResolution": "node",
        "target": "ESNext",
        "lib": ["ESNext"],
        "types": ["node", "jest"],

        "strict": true,
        "strictPropertyInitialization": false,

        "experimentalDecorators": true,
        "emitDecoratorMetadata": true,

        "incremental": true,
        "sourceMap": true,

        "forceConsistentCasingInFileNames": true,
        "noFallthroughCasesInSwitch": true,

        "resolveJsonModule": true,
        "esModuleInterop": true,

        "baseUrl": ".",
        "outDir": "./_output/build",
        "paths": {
            "app-common": ["src/app-common/index"],
            "applications": ["src/applications/index"],
            "cores": ["src/cores/index"],
            "infrastructures": ["src/infrastructures/index"],
            "controllers": ["src/controllers/index"]
        }
    },
    "include": ["src/**/*"]
}
